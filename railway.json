{
  "services": [
    {
      "type": "web",
      "name": "qlda-backend",
      "env": "python",
      "plan": "free",
      "region": "singapore",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "python -m backend.run",
      "healthCheckPath": "/",
      "envVars": [
        { "key": "FLASK_ENV", "value": "production" },
        { "key": "SECRET_KEY", "generateValue": true },
        { "key": "JWT_SECRET_KEY", "generateValue": true },
        { 
          "key": "DATABASE_URL", 
          "fromDatabase": {
            "name": "qlda-postgres",
            "property": "connectionString"
          }
        },
        { "key": "FRONTEND_URL", "value": "https://qlda-frontend.up.railway.app" },
        { "key": "MAIL_SERVER", "value": "smtp.gmail.com" },
        { "key": "MAIL_PORT", "value": "587" },
        { "key": "MAIL_USE_TLS", "value": "true" },
        { "key": "DEBUG", "value": "false" }
      ]
    },
    {
      "type": "web",
      "name": "qlda-frontend",
      "env": "static",
      "plan": "free",
      "region": "singapore",
      "buildCommand": "cd frontend && npm install && npm run build",
      "publishPath": "frontend/dist",
      "envVars": [
        { "key": "VITE_API_BASE_URL", "value": "https://qlda-backend.up.railway.app" }
      ]
    },
    {
      "type": "postgres",
      "name": "qlda-postgres",
      "plan": "free",
      "region": "singapore",
      "databaseName": "qlda_db"
    }
  ]
}